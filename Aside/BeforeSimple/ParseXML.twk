int PathParseXMLNow(PLGitem iTEM)
{
PLGitem up = iTEM["up"];
PLGitem path = iTEM["path"];
ParseXML	p = iTEM.testParser;
    if up up.runDeferred();
    if up["slash"]
        for path
            {
            path.runDeferred();
            if path["slash"] continue;
            or path.next
                {
                cerr "Invalid path: expected a /":;
                block = null;
                break;
                }
            }
    or path
        {
        cerr "Invalid path: expected a /":;
        block = null;
        }
return true;
}

