	/*************************************************************************
		Set block status wrt being open or closed
	*************************************************************************/
    if !singleton
        {
        isClosed    = false;
        isSingleton = false;
        ancestor    = block;
        openTags++;
        }
    else {
        singleton.run();
        isSingleton = true;
        }
}

