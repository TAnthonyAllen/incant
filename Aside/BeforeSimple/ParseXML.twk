void CommandText4ParseXMLAct(PLGitem iTEM)
{
PLGitem flag = iTEM["flag"];
ParseXML	p = iTEM.testParser;
/*****************************************************************************
    Process Flags
*****************************************************************************/
	if flag.start == 'd' debug              = !debug;
    or flag.start == 'e' simpleSyntax       = !simpleSyntax;
    or flag.start == 'm' doNotExpandMacros  = !doNotExpandMacros;
    or flag.start == 's'
        {
        cout "Exiting":;
        stopParsing = true;
        }
    or flag eq "noJIT"      { noLineByLine  = !noLineByLine; }
    or flag eq "noPrint"    { ignoreNoPrint = !ignoreNoPrint; }
    else cout "pausing":;
}

