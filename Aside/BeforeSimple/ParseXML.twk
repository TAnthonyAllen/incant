PLGitem run(String name)
{
	initializeKeyWords();
	if !rules.length
		{
		setRules();
		initialize();
		}
	return parse(name);
}
}
/*******************************************************************************
                Rule actions
            *******************************************************************************/

void AttributeParseXMLAct(PLGitem iTEM)
{
PLGitem target = iTEM["target"];
PLGitem name = iTEM["name"];
PLGitem value = iTEM["value"];
PLGitem modify = iTEM["modify"];
ParseXML	p = iTEM.testParser;
PLGitem			field   = name["field"];
PLGitem			regex   = field/"regex";
String          fieldID = field.toString();
PLGitem			dollar,
                item,
				text,
				valueRegex;
GroupItem		block;
PLGrgx			rgx;

	currentBlock = null;
	if value
		{
        dollar      = value["dollar"];
		text        = value["text"];
		valueRegex  = value["regex"];
		}
    if settingPath currentBlock = new(fieldID);
	if !currentBlock    currentBlock = locate(fieldID);
    if !currentBlock    currentBlock = new(fieldID);
    if target
        {
        String atText = target.string();
        while *atText
            {
            if atText == '@'
                currentBlock.isTarget = true;
            or atText == '%'
                currentBlock.noAnchor = true;
            atText++;
            }
        target.unString();
        }
	if modify modify.runDeferred();
    /*********************************************************************
        Check for tag regular expression. Note that the currentBlock
        text is not set. Check for isAny and isEOF.
    *********************************************************************/
    if regex
        {
        fieldID++;
        rgx = new(fieldID);
        currentBlock.regex  = rgx;
        }
    if field/"any"
        if field.itemStart == '*' currentBlock.isAnyGRP = true;
        else currentBlock.isEOFGRP = true;
    //cout `"Attribute: " currentBlock.tag:;

	/*************************************************************************
		Process value if there is one and compile value regular expressions
	*************************************************************************/
	if value
		{
        if currentBlock.isRegexGRP
            cerr "Error: " fieldID " is regex and cannot have a value: " value:;
        item = value/"number";
        if item
            {
            if item.floating
                currentBlock.number = item.amount;
            else currentBlock.count = (int)item.amount;
            if value/"percent"
                currentBlock.isPercent = true;
            }
        or valueRegex
            {
            rgx = new(text.toString());
            currentBlock.regex = rgx;
            }
        else {
            if dollar
                currentBlock.isMacro = true;
            or text
                if currentRegistry.isRule && (block = locate(text))
                    if block != currentBlock
                        {
                        block               = new(block);
                        currentBlock.group  = block;
                        block.parent        = currentBlock;
                        }
                    else cerr "Attribute: tried to assign",block.tag,"to itself":;
                or text.isSetPLG        currentBlock.characterSet = (PLGset)text.value;
                else currentBlock.item = text;
            }
		}
    if firstTag firstTag = false;
    or !currentBlock.registry
        currentBlock.isAttributeGRP = true;
doneAttribute:
    field.value	= currentBlock;
}

void CommandTextParseXMLAct(PLGitem iTEM)
{
PLGitem file = iTEM["file"];
ParseXML	p = iTEM.testParser;
includeFile(file.string());
    file.unString();
}

int EndTagParseXMLNow(PLGitem iTEM)
{
PLGitem action = iTEM["action"];
PLGitem field = iTEM["field"];
ParseXML	p = iTEM.testParser;
GroupItem   group = ancestor;
    if field
        while group && field ne group.tag
            { group = group.parent; }
return true;
}

void EndTagParseXMLAct(PLGitem iTEM)
{
PLGitem action = iTEM["action"];
PLGitem field = iTEM["field"];
ParseXML	p = iTEM.testParser;
GroupItem	listTag;
	currentBlock = ancestor;
    if field
        while currentBlock
            if currentBlock.tag eq field
                break;
            else currentBlock = currentBlock.parent;
	if !currentBlock
		{
        if field
            {
            listTag			= new(field);
            field.isEndTag	= true;
            }
        else listTag = new;
		listTag.noTag	= true;
        listTag.isSingleton = true;
        if !ancestor
            {
            if outerBlock && !outerBlock.isClosed && !outerBlock.isSingleton
                currentBlock = outerBlock;
            else currentBlock = listTag;
            }
		}
	if listTag
		{
		if ancestor
            {
            if ancestor.hasMembers
                ancestor += listTag;
            or field
                {
                PLGitem item    = ancestor.item;
                field.isEndTag  = true;
                if item item += field;
                else ancestor.item = field;
                }
            currentBlock = ancestor;
            }
		or listTag != currentBlock
			currentBlock += listTag;
		endTags += listTag;
		}
    else {
		while ancestor && ancestor != currentBlock
			{
			ancestor.isClosed = true;
			ancestor = ancestor.parent;
			}
		currentBlock.isClosed = true;
		ancestor = currentBlock.parent;
        if !ancestor    outerBlock = currentBlock;
		openTags--;
		}
    if action action.run();
}

void JSONrepeatEntryParseXMLAct(PLGitem iTEM)
{
PLGitem data = iTEM["data"];
ParseXML	p = iTEM.testParser;
data.runDeferred();
}

void JSONpairParseXMLAct(PLGitem iTEM)
{
PLGitem name = iTEM["name"];
PLGitem data = iTEM["data"];
ParseXML	p = iTEM.testParser;
String      fieldName = name.toString();
   if fieldRegistry
        {
        GroupItem   rename = fieldRegistry[fieldName];
        if rename   fieldName = rename.text;
        }
    currentBlock    = new(fieldName);
    if !ancestor
        if list list += currentBlock;
        or currentRegistry currentRegistry += currentBlock;
        else cerr "JSONpair rule: do not know what to load",currentBlock.tag,"into":;
    //cout "JSONpair: created a new block",fieldName:;
    data.runDeferred();
}

int RegistryParseXMLNow(PLGitem iTEM)
{
PLGitem type = iTEM["type"];
ParseXML	p = iTEM.testParser;
GroupItem   registri;
    type = type["text"];
    if registries && type ne "registries"
        {
        registri = registries[type.string()];
        type.unString();
        if !registri
            {
            //cout "Registry rule failed:",type:;
            return false;
            }
        }
    type.value = registri;
return true;
}

int LocateParseXMLNow(PLGitem iTEM)
{
PLGitem type = iTEM["type"];
PLGitem field = iTEM["field"];
ParseXML	p = iTEM.testParser;
GroupItem       registri,
                group;
PLGitem         item = field["text"];
String          text = item.string();
    if type
        registri = type.value;
    if registri group = registri/text;
    else group = locate(text);
    item.unString();
    if group field.value = group;
    else return false;
return true;
}

int ModifierParseXMLNow(PLGitem iTEM)
{
PLGitem limit = iTEM["limit"];
PLGitem modifier = iTEM["modifier"];
PLGitem alternate = iTEM["alternate"];
ParseXML	p = iTEM.testParser;
    if !modifier && !limit && !alternate
        return false;
return true;
}

void ModifierParseXMLAct(PLGitem iTEM)
{
PLGitem limit = iTEM["limit"];
PLGitem modifier = iTEM["modifier"];
PLGitem alternate = iTEM["alternate"];
ParseXML	p = iTEM.testParser;
GroupItem	attribute;
PLGitem     item;
int         modifiers;
    if modifier
        while modifiers < modifier.length
            switch (*(modifier.start + modifiers++))
                {
                case '!':
                    currentBlock.bangedGRP  = true;
                    currentBlock.noMerge    = true;
                case '?':
                    currentBlock.questionGRP    = true;
                case '+':
                    currentBlock.plusGRP        = true;
                case '*':
                    currentBlock.starGRP        = true;
                case '}':
                    currentBlock.skipOverGRP    = true;
                case '{':
                    currentBlock.processUpToGRP = true;
                case '%':
                    currentBlock.noAdvance      = true;
                case '<':
                    currentBlock.isContainerGRP = true;
                case '&':
                    currentBlock.noSkip         = true;
                }
    if limit
        {
        if item = limit["minimum"]
            if item.amount != 1
                {
                attribute       = currentBlock["min"] = item.amount;
                attribute.noPrint       = true;
                currentBlock.hasMinGRP  = true;
                }
        if item = limit["maximum"]
            if item.amount != 1
                {
                attribute	= currentBlock["max"] = item.amount;
                attribute.noPrint       = true;
                currentBlock.hasMaxGRP  = true;
                }
        }
	if alternate currentBlock.isAlternate = true;
}

int NumberParseXMLNow(PLGitem iTEM)
{
PLGitem number = iTEM["number"];
PLGitem part = iTEM["part"];
ParseXML	p = iTEM.testParser;
    if part
        {
        number.length += part.length;
        number.floating = true;
        }
    number.amount = atof(number.string());
    number.unString();
return true;
}

