void SimpleEnd2ParseXMLAct(PLGitem iTEM)
{
PLGitem close = iTEM["close"];
PLGitem field = iTEM["field"];
ParseXML	p = iTEM.testParser;
int i;
GroupItem   block = currentBlock;
    block.isSingleton    = true;
    while block && i++ < close.length
        {
        block.isClosed   = true;
        block = block.parent;
        }
    if field
        while block
            {
            block.isClosed   = true;
            if block.tag eq field    break;
            block = block.parent;
            }
    if ancestor && ancestor.isClosed
        ancestor = ancestor.parent;
}

