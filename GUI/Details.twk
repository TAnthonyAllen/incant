	Scroll if x or y scroll amount set - right now scrolls horizontal or vertical
    not both. For 2D scroll, break into two parts.
*******************************************************************************/
void setScroll(int step,int goAcross)
{
    cout "setScroll has to be rewritten":;
}

/******************************************************************************
	Return the style in effect (which may be a copy of ancestor style).
******************************************************************************/
void setStyle()
{
Details ancestor = wig.parent ? wig.parent.getDetail() : null;
    if style return;
    if ancestor && ancestor.style
        style   = new(wig,ancestor.style);
    else style  = new(wig);
    /***************************************************************************
        Set filler and selectFill.
    ***************************************************************************/
GroupItem   group = wig.findAttribute("fill");
String      name;
    if group
        {
        if name = text
            if name != '#'
                {
                filler  = locate(name);
                if !filler      cerr "setStyle could not find fill:",name:;
                else group.text = filler.text;
                }
        filler = group;
        }
    if group = wig%"selectFill"
        {
        if name = text
            if name != '#'
                {
                selectFill = locate(name);
                if !selectFill  cerr "setStyle could not find selectFill:",name:;
                else group.text = selectFill.text;
                }
        selectFill = group;
        }
}
