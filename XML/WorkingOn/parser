/*******************************************************************************
	TokenXP returns a token or a token expression.
*******************************************************************************/
extern GroupItem aCTionTokenXP(GroupItem xpress)
{
GroupItem   arg,
            op,
            UnaryOPS:,
            InvokeArg = xpress["InvokeArg"],
            ANYtoken = xpress["ANYtoken"];
    xpress.clear();
    if isGROUP  ANYtoken = group;
    if UnaryOPS {
        op  = new("uxp");
        op  +% UnaryOPS;
        op  +% ANYtoken;
        op.method = runOP;
        op.invoke = true;
        if InvokeArg ANYtoken = op;
        else {
            xpress.group = op;
            goto endToken; }}
    if !InvokeArg {
        if registry == groupFields {
            op = opFields["."];
            xpress  +% op;
            xpress  +% ANYtoken;
            // w/no argument opDot will try to use lastREF
            xpress.invoke = true; }
        else xpress.group = ANYtoken; }
    else {
        if InvokeArg.groupList {
            // this happens when InvokeArg is UnaryXP
            op  = InvokeArg.firstInList;
            arg = InvokeArg.lastInList;
            if op.isGROUP   op = op.group;
            if arg.isGROUP  arg = arg.group;
            xpress  +% op;
            xpress  +% ANYtoken;
            xpress  +% arg; }
        else {
            if InvokeArg.fLAG op = opFields["."];
            else    op = falseResult;
            if InvokeArg.isGROUP arg = InvokeArg.group;
            if !arg arg = InvokeArg;
            xpress  +% op;
            xpress  +% ANYtoken;
            xpress  +% arg; }
        xpress.invoke = true; }
    if xpress.invoke    xpress.method = runOP;
endToken:
    return xpress;
}
