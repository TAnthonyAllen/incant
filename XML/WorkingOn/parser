/***************************************************************************
    runPlusEQ — pop two, run opPlusEQ, copying its data into the sum.sum is
    pushed onto the stack even on a null result (stays empty), keeping the
    stack depth predictable.
***************************************************************************/
extern GroupItem runPlusEQ(GroupItem instr)
{
GroupItem   stack  = opStackOf(instr);
GroupItem   op2    = stack.pop();
GroupItem   op1    = stack.pop();
GroupItem   result = opPlusEQ(op2, op1);
GroupItem   sum    = new("sum");
    if result   sum.copyData(result);      // copy value off the result (op1)
    stack.push(sum);
    return null;
}
