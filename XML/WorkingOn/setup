//Setting up
/*******************************************************************************
    cOMMANDs is a base registry defined on startup with a few commands added
    before bootstrapping. Here it is extended by adding more commands.
    
	Commands fire C++ methods used to set flags, whatever. They have an associated
    method specified by the immediateAction attribute, which is a noPrint attribute.
    noPrint attributes are fire and forget. They change the group being defined but are
    not added as a group attribute once forgotten. For example, the isRule
    command/attribute makes the group it appears in a rule, then it disappears so
    it does not become a rule attribute to be processed when the rule is parsed.
    
    Commands that are not noPrint are designed to be command line methods. They
    are invoked as command(argument).
*******************************************************************************/
registry(cOMMANDs);
define
    include=loadInputFromFile immediateAction;
    virtual immediateAction=processFlags noPrint;
    assign immediateAction=processFlags noPrint;
    bin immediateAction=processFlags noPrint;
    bitmap immediateAction=setInternalType noPrint;
    buffer immediateAction=setInternalType noPrint;
    class immediateAction=rEGISTER noPrint;
    clear immediateAction=cLEAR;
    condition immediateAction=processFlags noPrint;
    copy immediateAction=cOPY;
    debugGuard immediateAction=debugOnGuard noPrint;
    defer immediateAction=processFlags noPrint;
    draw immediateAction;
    dumpContents immediateAction;
    exit immediateAction=processFlags;
    file immediateAction=setInternalType noPrint;
    generateCode immediateAction;
    genPrint immediateAction;
    getType immediateAction;
    guard immediateAction noPrint;
    index immediateAction=processFlags noPrint;
    isList immediateAction=processFlags noPrint;
    isRule immediateAction=processFlags noPrint;
    listenTo immediateAction noPrint;
    load immediateAction=loadDirectory noPrint;
    macro immediateAction=processFlags noPrint;
    merge immediateAction=processFlags noPrint;
    new immediateAction=makeNew;
    printTO immediateAction=printToBuffer;
    quoted  immediateAction;
    regex immediateAction=setInternalType noPrint;
    register immediateAction=rEGISTER noPrint;
    setLabel immediateAction;
    sort immediateAction=processFlags noPrint;
    stack immediateAction=setInternalType noPrint;
    stop=stopParsingInput immediateAction;
    testing immediateAction;
    unary immediateAction=processFlags noPrint;
    ;
/*******************************************************************************
	Operators is a base registry defined at startup and extended here. Unlike
    most registries, it is unsorted, however, it is loaded in descending order
    (so when comparing against an input stream, longest match is returned by the parse).
*******************************************************************************/
registry(Operators);
define
    '~='    operateMethod=opMatch;
    '|';
    '^';
    OR      operateMethod=opOR;
    IN      operateMethod=opIN;
    GO;
    AND     operateMethod=opAND;
    '?';
    '>>';
    '>='    operateMethod=opGE;
    '>'     operateMethod=opGT;

    '=='    operateMethod=opEQ;
    '=['    operateMethod=opGet;
    '=/'    assign operateMethod=opGetMember;
    '=*'    operateMethod=opAssignGroup;
    '=%'    assign operateMethod=opGetAttribute;
    '='     assign operateMethod=opAssign;

    '<='    operateMethod=opLE;
    '<<';
    '<:';   // DQ
    '<'     operateMethod=opLT;

    ':>';
    ':='    operateMethod=opSetGroup;
    ':<';   // not used
    ':-';   // pop not written yet
    ':+'    operateMethod=opReplace;
    '/='    operateMethod=opSlashEQ;
    '/'     operateMethod=opSlash;
    '.'     operateMethod=opDot;
    '-='    operateMethod=opMinusEQ;
    '--'    unary ruleMethod=opMinusMinus;

    '-'     operateMethod=opMinus;
    '+='    operateMethod=opPlusEQ;
    '++'    unary ruleMethod=opPlusPlus;
    '+*'    operateMethod=opCopyList;
    '+%'    operateMethod=opAddAttribute;
    '+'     operateMethod=opPlus;
    '*='    operateMethod=opMultiplyEQ;
    '*'     operateMethod=opMultiply;
    '@'     unary ruleMethod=opLastREF;
    '&';
    '%'     operateMethod=opDiv;
    '!='    operateMethod=opNotEQ;
    '!'     unary ruleMethod=opNOT;
    '+/';
    '**'    unary ruleMethod=opDebug;
    ;
/*******************************************************************************
	pROPERTIEs is a base registry defined on startup and extended here
*******************************************************************************/
registry(pROPERTIEs);
define
    atEND;
    currentPOINT;
    currentFRAME;
    extern noPrint;
    fAIL noPrint;
    gUARD noPrint;
    hexSet=[0-9a-fA-F];
    // ListOP is used as a rule but entered here so it will not be a rule (nor its members)
    ListOP bin:
        '=/';
        '=%';
        ':+';;
    null=0;
    notInNameSet=[^a-zA-Z0-9];
    stringBUFFER;
    UnaryOPS bin:
        '--';
        '++';
        '@';
        '!';
        '**';
        '.';;
    ;
/*******************************************************************************
	Keywords is a base registry defined on startup. It contains groups that play
    a role in the grammar. Keywords cannot be used as fields (the NamE rule rejects them);
*******************************************************************************/
registry(Keywords);
define
    break;
    continue;
    debug;
    define;
    do;
    else;
    for;
    if;
    new;
    next;
    or;
    print;
    return;
    scope;
    search;
    string;
    this;
    while;
    ;
/*******************************************************************************
	GroupFields is a base registry defined on startup and filled here. It
    contains fields linked to C++ GroupItem fields so they can be accessed by incant.
    The last letter in tags below are capitalized to avoid overlaps w/other
    registry entries
*******************************************************************************/
registry(GroupFields);
define
    taG=1;
    parenT=2;
    registrY=3;
    texT=4;
    listLengtH=5;
    datA=6;
    hasAttributeS=7;
    hasMemberS=8;
    isLocaL=9;
    isArgumenT=10;
    invokE=11;
    // The following flags should probably be made available via opDot()
    flaG;
    isConditioN;
    isFilE;
    isIndexeD;
    isInitializeD;
    isLiteraL;
    isMacrO;
    isMethoD=19;
    isOperatoR=20;
    isPercenT;
    isPointeR;
    isRulE;
    isShortcuT=24;
    isVirtuaL;
    mergeON;
    negatE;
    noPrinT=28;
    noSkiP;
    ;
registry(fILEs);
define
    grammar File='XML/WorkingOn/grammar';
    drawing File='XML/WorkingOn/drawing';
    utilities File='XML/WorkingOn/utilities';
    unitTests File='XML/WorkingOn/unitTests';
    generate File='XML/WorkingOn/generate';
    ;
