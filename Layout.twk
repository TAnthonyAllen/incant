/*******************************************************************************
	Layout view
*******************************************************************************/
class Layout extends View implements WindowDelegate
{
GroupItem       base,
                selection;
Path            layoutPath;
Color           strokeColor,
                textColor,
                wallColor;
Font            currentFont;

/*******************************************************************************
	Display text
void displayText(GroupItem field)
{
Box				box;
TextView		editor;
String			alignment;
Frame           framed = getFrame(field);
	if object
		editor = object;
	else {
        editor  = getTextView(field);
        object  = editor;
        box = editor.textContainer;
		box.trackHeight(true);
		box.trackWidth(true);
		if group = field["align"] alignment = group.text;
		if alignment
			if alignment == 'c'
				editor.align(alignCenter);
			or alignment == 'l'
				editor.align(alignLeft);
			or alignment == 'r'
				editor.align(alignRight);
        editor.bgColor = clearColor;
        editor.setFont(style.getFont());
        editor.setEditable(false);
		}
    editor.setFrame(framed);
    if !subbed
        {
        addSubview(editor);
        subbed  = true;
        }
    //editor.displayIfNeededIgnoringOpacity();
}
*******************************************************************************/

/*******************************************************************************
	Draw
*******************************************************************************/
void drawRect(Frame r)
{
    cout "drawRect: not written yet":;
}

Layout init(Frame f)
{
    frame       = f;
    layoutPath  = bezierPath();
    return self;
}

/*******************************************************************************
	Invert the y coordinate of the point passed in to correspond to top down
    orientation and return revised point
*******************************************************************************/
Point invertY(Point point)
{
double  baseY = frame.height - point.y;
    point.y = baseY;
    return point;
}

/*******************************************************************************
	Handle key clicks
        If selection does not have a key action
        searches parent hierarchy for a block that does have a key action
*******************************************************************************/
void keyUp(Event event)
{
    cout "Layout keyUp":;
}

/*******************************************************************************
	Handle mouse clicks
*******************************************************************************/
void mouseUp(Event event)
{
    cout "Layout mouseUp":;
}

/*******************************************************************************
	Handle right mouse click
*******************************************************************************/
void rightMouseUp(Event event)
