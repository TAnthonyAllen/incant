/*******************************************************************************
	Handle scroll wheel events
*******************************************************************************/
void scrollWheel(Event event)
{
double		delta;
int			down,
			length;
    //paging  = false;
	delta   = deltaY();
	if delta < 0
		{
		down = true;
		length = -delta;
		}
	else length = delta;
	if !length length++;
    if down length = -length;
    // if direction is down, length is negative
    /***************************************************************************
        HPDL
Point		point = convertPoint(mouseAt(),nil);
GroupItem   block;
    if selection
        selection.scrollBlock(length,1);
    or block = base.blockContaining(point)
        block.scrollBlock(length,1);
    ***************************************************************************/
}

void viewDidEndLiveResize()
{
	cout "View End resize":;
    setFrame(superview.frame);
    //base.updateFrame(frame);
    drawRect(frame);
}

void windowWillClose(Notification notification)
{
    cout "Window closing: will exit":;
    exit(0);
}
