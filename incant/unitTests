register(UnitTests);
define
    /*************************************************************************
        Data
    *************************************************************************/
    maximus=11;
    righty=13;
    styleTest merge lightGreen rounded;
    sumple="What if it is a long string." height=200 width=250 x=100 y=100 down=*
        crossing height=50;
    simple across styleTest height=212 width=250 x=100 y=100
        quinto width=150;
        sexto height=12;
        fifth;
    sample x=300 y=450 width=400 height=200
        second;
        third pad=5 fill=wall across
            wrap="This is a whole lot of text that I am using to test out text views, scrolling, and isn't it nice that the xcode text editor wraps lines and indents auto-magically. The base rule is you have to specify everything you want, nothing implied." fill=purple
                one text pad=7 border;
            two fill=red left=2;
            three fill=white width=50% left=2
                stuff text=one pad=6;
        fourth rounded pad fill=lightGreen height=12;
        fifth;
    aGroup one two three;
    hasGroup=simple;

    /*************************************************************************
        Actions
        Each action below tests a single incant rule or statement to verify it
        parses and executes as intended. Where incant behavior differs from C++
        that difference is noted explicitly.

        Note: printTest and stringTest are intentionally paired as both a unit
        test and a teaching example. This is a pattern worth following for other
        actions where incant diverges sharply from C++ — the test that proves it
        works is also the best explanation of what it does.

        POPs below are taken from captured testUnitTests output (2026-06-02).
        Actions NOT exercised by testUnitTests are marked unverified and are on
        the legacy-POP sweep (see TODO); some are known broken (callMyself).
    *************************************************************************/
    // Tests: field attribute-presence access (argument.across)
    // POP: accessTest(simple) -> "Saw across in simple"  (simple IS declared with across)
    accessTest argument code={ print "accessTest: " taG; if argument.across; print `"Saw across in" taG:; else print `"No across in" taG:; };
    // Tests: arithmetic expression on a field value
    // POP: "anotherTest: max should be 11 + 3  it is 14 and we done"
    anotherTest code={ print "anotherTest: max should be" maximus " + 3"``"it is", maximus + 3, "and we done":; };
    // Tests: recursive action invocation
    // POP: BROKEN — infinite recursion: righty++ does not persist across the
    //      self-recursive call so righty==13 never goes false. Not in
    //      testUnitTests. See TODO (reentrancy / legacy-POP).
    callMyself argument code={
        print ~"callMyself: First time:" argument righty,:+;
        if righty == 13;
            righty++;
            callMyself(aGroup);
        print ~"Second time:" argument righty,:-;
        };
    commaStuff="44,two,  forty three,six,6.7,ninety one";
    delimitRecord isRule countField}=1 skip-}=3 numberField}=1.0 stringField};
    feeling='having a few doubts ends here';
    // Tests: printf-style format string (%12s)
    // POP: not in testUnitTests — unverified (TODO legacy-POP)
    formatTest code={ print "formatTest:" `is "Formatted"%12s maybe:; };
    // Tests: if/or/else with a nested if/or/else, inside a for loop
    // Note: incant uses 'or' where C++ uses 'else if'; the chain is not
    //       bracketed — indentation and keywords define the structure.
    // POP: "one" -> "outer-then, inner-then"; "two" -> "outer-or";
    //      "three" -> "outer-else"
    ifTest code={
        print "ifTest:":;
        for grup in aGroup;
            print ``"grup=" grup.taG ":":;
            if grup.taG == "one";
                if righty == 13;
                    print "  outer-then, inner-then":;
                or righty == 99;
                    print "  outer-then, inner-or":;
                else
                    print "  outer-then, inner-else":;
            or grup.taG == "two";
                print "  outer-or":;
            else
                print "  outer-else":;
        };
    // Tests: action invocation and clear()
    // POP: not in testUnitTests — unverified (TODO legacy-POP)
    invokeTest code={ print "invokeTest:"` clear(aGroup); anotherTest(); print Invoked:; };
    jsonFile file="/Users/anthony/Dropbox/data/InProcess/Groups/Tests/test.json";
    // Tests: parent field access and local variable assignment
    // POP: not in testUnitTests — unverified (TODO legacy-POP)
    layout code={ gruber = 23; print "layout:"`"Here is" parent.taG and gruber:; };
    // Tests: user-defined rule (isRule) with an entry pattern + for loop
    // Note: unlike an action, list is a RULE — it parses its input stream
    //       directly. Rule attributes (entries=ANYstring+ SemI?-) define the
    //       parse pattern; on success their results bind to like-named rule
    //       fields. The code= block IS the rule action (no separate callback).
    // POP: list("righty 3.1 seven eight nine;") prints each token on its own line
    list isRule entries=ANYstring+ SemI?- code={
        print "list tests the for statement:":;
        for sumGrup in entries; print `sumGrup:; };
    // Tests: field carrying both an initial value and code that fires on reference
    // Note: lefty=3 sets the value; the code block runs when lefty is referenced.
    //       Unlike C++, a field can hold a value AND run code on use.
    // POP: "lefty: got reset to 46"  (exercised via printTest)
    lefty=3 code={ lefty += 43; print "lefty:"``"got reset to" lefty:; return lefty; };
    // Tests: calling an action that returns a value (lefty())
    // POP: "printTest: lefty should return itself. It returns 46"
    // (Proposed expansion to demo each print modifier is a separate logic task.)
    printTest code={ print "printTest:"`"lefty should return itself. It returns" lefty():; };
    // Tests: if/else with a field assignment in each branch, then calls anotherTest
    // POP: righty truthy so maximus = righty+35 = 48; anotherTest then prints
    //      "max should be 48 + 3  it is 51 and we done"
    simpleIF code={ print "simpleIF:":`; if righty; maximus = righty + 35; else maximus = 12; anotherTest(); };
    // Tests: 'string' captures print-style output into a field
    // Note: string uses identical syntax to print — same shortcuts, same
    //       concatenation. Where print emits a line, string returns it as a
    //       field value. Compare printTest, which prints directly.
    // POP: "stringTest:  59 added 2 to righty is what I am talking about"
    stringTest code={ print "stringTest:"`what = righty + 2, "added 2 to righty" $whatsIt; };
    // Tests: logical OR and ! negation in an if condition
    // Note: incant parses '!righty OR feeling' as !(righty OR feeling) — '!'
    //       scopes the WHOLE following expression, not just righty (unlike the
    //       C++ reading (!righty) OR feeling). righty=13 and feeling set, so
    //       !(true OR true) = false -> the else branch.
    // POP: "testOR:  I see nothing"
    testOR code={ print "testOR:"`; if !righty OR feeling; print Saw righty feeling:; else print "I see nothing":; };
    // Tests: argument passing, including an inline expression as the argument
    // Note: an argument can be an expression, not just a field reference
    // POP: testARG(hasGroup) -> "Argument is: hasGroup";
    //      testARG(righty += 22) twice -> "Argument is: 35" then "57"
    testARG argument code={ print "testARG: Argument is:" argument:; };
    // Tests: for loop over attributes with multiple action arguments
    // Note: 'attributes' restricts the loop to attribute fields only
    // POP: not in testUnitTests — unverified (TODO legacy-POP)
    testForC argument second=56 third="WTF?" code={
        print "testForC:"`"Components of" argument with second third:;
        for grup in argument; attributes
            print `grup += righty:; };
    // Tests: indexed field write and read via []
    // POP: "testGet: should set sumple width to 251. It is 251"
    testGet code={ sumple[width] = 251; print "testGet: should set sumple width to 251. It is", sumple.width:; };
    // Tests: print indent modifiers (~ apply, + increase, - decrease)
    // Note: indent level is print state and persists across print statements
    // POP: One/Two indented, then Three/Four dedenting
    testIndentBlock code={
        print "testIndentBlock:":;
        if righty;
            print ~++One:;
            print ~Two:;
        print ~-Three:;
        print ~-Four:; };
    // Tests: ! negation on an undefined field
    // POP: not in testUnitTests — unverified (TODO legacy-POP)
    testNegate code={ print "testNegate: does not matter if the ! comes before or after"`; if !whatever; print "No result":; else print "Negate failed":; };
    // Tests: new() to create a fresh GroupItem, then ++ to increment
    // Note: new(argument) creates a field named for argument's tag
    // POP: not in testUnitTests — unverified (TODO legacy-POP)
    testNew argument code={ grup = new(argument); grup++; return grup; };
    // Tests: pointer arithmetic and the & dereference modifier
    // Note: argument = lineIn + 4 is pointer arithmetic; argument& dereferences.
    //       Unlike C++, & is a field modifier, not a type declaration.
    // POP: not in testUnitTests — unverified (TODO legacy-POP)
    testPointer lineIn code={
        print "testPointer:"`;
        argument = lineIn + 4;
        if argument& > lineIn; print "Yes it is":; else print "No it aint":; };
    // Tests: invoking a rule from inside an action
    // POP: "Processing testList action that runs list rule" then the list output
    //      (exercised via testInterpret)
    testList code={
        print `"Processing testList action that runs list rule":;
        list("righty 3.1 seven eight nine;"); };
    // Tests: the ':' scope operator binding local names from another group
    // Note: ':argument width height' binds width/height from argument into local
    //       scope — no C++ equivalent
    // POP: not in testUnitTests — unverified (TODO legacy-POP)
    testScope argument code={
            :argument width height;
            print taG width height:;
            :simple width height quinto@;
            print taG width height:; };
    // Tests: prefix ++ unary operator
    // Note: incant unary operators must PRECEDE their operand — no postfix form
    // POP: "++grup is 1" then "now grup++ is still 1 Unary operators must
    //      preceed their argument"  (exercised via testInterpret)
    testUnary code={
        print "testUnary:":;
        if ++grup; print ``"++grup is" grup:;
        if grup++; print ``"now grup++ is still" grup "Unary operators must preceed their argument":; };
    // Tests: integration of if/else, do/while, while, and for in one action
    // Note: good smoke test — exercises multiple statement types in sequence;
    //       also drives testUnary and testList
    // POP: sequential output from each statement type, ending with "we DONE"
    testInterpret code={
        print "testInterpret":`"dot test:", maximus.taG:;
        maximus = 11;
        if maximus; print `"Processed IF:", maximus += 4:;
        else
            print `"or else":;
            maximus = 11;
        print `"Process do:":;
        do
            maximus += 2;
            print  ``Saw maximus:;
        while maximus < 20;
        print `"Process while:":;
        while maximus <= 27;
            maximus += 3;
            print ``Saw maximus:;
        print `"Process for loop:":;
        for grup in styleTest;
            print ``Saw grup.taG:;
        //print `"Process method call in print: New righty =" testNew(righty) "Old righty =" righty:;
        grup = 0;
        testUnary();
        testList();
        print ``"we DONE":;
        };
    whatsIt;
    // Tests: ++ used inline in a print expression
    // Note: incant ++ precedes its operand and returns the incremented value
    //       (no separate pre/post forms as in C++)
    // POP: "xpTest:  HooHaa 4 5 Gomer is a goober is what I am talking about"
    //      (result starts 3, ++result twice -> 4 then 5; whatsIt from the opener)
    xpTest HooHaa result=3 message="Gomer is a goober" code={ print "xpTest:" `HooHaa, ++result, ++result, message whatsIt:; };
    /*************************************************************************
        print out incant definition for the group passed in
    *************************************************************************/
    printDefinition argument recurse code={
        **argument;
        if datA != 0;  print ~$taG "=" argument;
        else    print ~$taG;
        if hasAttributeS;
            for grup in argument; attributes
                if datA != 0;
                    print $_taG "=" grup;
                else    print $_taG;
        if hasMemberS;
            print :;
            for grup in argument; members
                print +;
                printDefinition(grup);
                print ,-;
        else
            print ";":;
        };

/*****************************************************************************
	Unit Test runner — calls every action in the Unit Tests block, moved here
	from oneTest so the tester file just invokes testUnitTests().
*****************************************************************************/
    testUnitTests code={
        whatsIt = string 'is what I am talking about':;
        print ``This $whatsIt;
        accessTest(simple);
        anotherTest();
        ifTest();
        printTest();
        simpleIF();
        testOR();
        testARG(hasGroup);
        testARG(righty += 22);
        testARG(righty += 22);
        testIndentBlock();
        stringTest();
        xpTest();
        list("righty 3.1 seven eight nine;");
        testInterpret();
        testGet();
        printDefinition(sumple);
        printDefinition(simple);
        printDefinition(sample);
        };
    ;
