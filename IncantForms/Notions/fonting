/****************************************************************************
	Return the point from the group passed in.
****************************************************************************/
Point *atPoint(GroupItem item)
{
Point       *point;
    if isPointer    point = (Point*)item.pointer;
    else {
        GroupItem   x = item[1],
                    y = item[2];
        point = calloc(1,sizeof(Point));
        point.x = x.number;
        point.y = y.number;
        }
    return point;
}

