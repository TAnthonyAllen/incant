                contentSet                  = input += "contentSet";
                contentSet.noPrint          = true;
                while item = next(item)     stuff.set(item.tag);
                contentSet.characterSet     = stuff;
                }
            else stuff = contentSet.characterSet;
            stringBUFFER.reset();
            atText      = stream;
            while stuff.contains(*atText)
                {
                stringBUFFER += *atText;
                atText++;
                }
            if atText > stream && !nameSet.contains(*atText)
                if name = stringBUFFER.string()
                    return get(name);
            }
