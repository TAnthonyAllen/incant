    /***********************************************************************
        Layout a long string into a set of fixed length blocks. This needs
        to change to return all the text that should fit in a display field
        using a buffer passed is as the text source (that is change lineIn
        to a buffer instead of a string)
    ***********************************************************************/
    layingOut lineIn lineLength lines nextLine&; {
        currentLine = lineIn;
        do
            if currentLine > lineLength;
                nextLine    = currentLine + lineLength;
                if nextLine IN ruleSkipSet;
                    while nextLine IN ruleSkipSet; nextLine++;
                else
                    until nextLine !IN ruleSkipSet;
                        nextLine--;
                        if nextLine IN ruleSkipSet;
                            nextLine++;
                            break;
                currentLine -= nextLine;
                lineOut     = currentLine;
                result      +/ new(lineOut);
                currentLine = nextLine;
            else
                lineOut     = currentLine;
                result      +/ new(lineOut);
                break;
        while lines-- > 0;
        return result;
        }

