/****************************************************************************
	Sets the frame attributes for the group passed in from the frame passed in.
****************************************************************************/
extern void updateFrame(GroupItem grup,Frame frame)
{
GroupItem   setFrame = locate("setFrame");
GroupItem   frameSource = grup % "frame";
GroupItem   x = frameSource % "x";
GroupItem   y = frameSource % "y";
GroupItem   width = frameSource % "width";
GroupItem   height = frameSource % "height";
    x.number    = frame.x;
    y.number    = frame.x;
    width.number    = frame.width;
    height.number   = frame.height;
    runAction(setFrame,grup);
}
