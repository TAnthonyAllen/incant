        This is the boundary where incant hands off to
        the LLVM IR builder. emitInline is a native
        method that calls the appropriate LLVM builder
        method based on llvmOp.
        e.g. for "fadd":
            builder.CreateFAdd(left, right)
    *****************************************************/
    nativeEmit(llvmOp, left, right);
}

emitNativeCall native left right; {
    /*****************************************************
        Emit an LLVM call instruction to the native
        method address stored in the registry entry
    *****************************************************/
