cpp/*************************************************************
    processNativeType - called when nativeType command is
    encountered during field definition. Stores the C++
    type signature and marks the field as a native address
    holder.

    The field being defined is 'this'. The nativeType
    attribute on 'this' contains the type signature string
    set by the parser e.g. "GroupItem*(GroupItem*,GroupItem*)"
*************************************************************/
GroupItem processNativeType(GroupItem field)
{
    GroupItem nativeTypeAttr = field.getAttribute("nativeType");
    String    signature;

    if !nativeTypeAttr
    {
        cerr "processNativeType: no type signature for" field.tag "\n";
        return null;
    }

    signature = nativeTypeAttr.text;

    /*********************************************************
        Parse the signature to extract return type and
        argument types. Store them as attributes on the
        field so the compiler can use them later.

        e.g. "GroupItem*(GroupItem*,GroupItem*)" becomes:
            returnType  = "GroupItem*"
            argTypes[0] = "GroupItem*"
            argTypes[1] = "GroupItem*"
    *********************************************************/
    field.isNativeType  = true;
    field.isPointer     = true;

    if parseSignature(field, signature)
    {
        /*****************************************************
            Look up the actual C++ function address using
            the same mechanism ruleMethod uses. If found
            store it as a pointer in the field.
        *****************************************************/
        void* address = lookupNativeAddress(field.tag);

        if address
            field.pointer = address;
        else
            cerr "processNativeType: no address found for"
                  field.tag "\n";
    }

    return field;
}
Now parseSignature which does the heavy lifting of breaking the signature string into its components:
cpp/*************************************************************
    parseSignature - parses a C++ function pointer signature
    string and stores the components as attributes on the
    field.

    Handles forms like:
        "void*(int)"
        "GroupItem*(GroupItem*,GroupItem*)"
        "int(char*)"
        "void()"
*************************************************************/
GroupItem parseSignature(GroupItem field, String signature)
{
    GroupItem returnTypeField,
              argTypeField;
    String    atSig     = signature,
              retType,
              argType;
    Buffer    typeBuf   = new();

    /*********************************************************
        Extract return type - everything before the '('
    *********************************************************/
    while *atSig && *atSig != '('
    {
        typeBuf += *atSig;
        atSig++;
    }

    retType = typeBuf.toString();

    if !retType
    {
        cerr "parseSignature: malformed signature" signature "\n";
        return null;
    }

    returnTypeField = new(retType);

    /*********************************************************
        Look up the return type in the types registry
        from the generate file so we can store the
        type code alongside the string
    *********************************************************/
    if Generating["types"][retType]
        returnTypeField.typeCode = nativeTypes[retType];

    field.addAttribute(returnTypeField);
    field.returnType = returnTypeField;

    /*********************************************************
        Skip past '(' and parse argument types
    *********************************************************/
    if *atSig == '(' atSig++;

    int argIndex = 0;

    while *atSig && *atSig != ')'
    {
        typeBuf.clear();

        while *atSig && *atSig != ',' && *atSig != ')'
        {
            typeBuf += *atSig;
            atSig++;
        }

        argType     = typeBuf.toString();
        argTypeField = new(argType);

        if Generating["types"][argType]
            argTypeField.typeCode = nativeTypes[argType];

        field.addAttribute(argTypeField);
        argIndex++;

        if *atSig == ',' atSig++;
    }

    field.argCount = argIndex;

    return field;
}
And lookupNativeAddress which ties into the existing ruleMethod mechanism:
cpp
/*************************************************************
    lookupNativeAddress - looks up the C++ address for a
    named method. Uses the same pattern matching mechanism
    as ruleMethod - searches for a method named with the
    aCTion prefix convention, then falls back to a direct
    name match in the runtime object.

    This is where we bridge from incant's name-based world
    to C++ function pointers.
*************************************************************/
void* lookupNativeAddress(String name)
{
    void* address = null;

    /*********************************************************
        First try the aCTion prefix convention used by
        ruleMethod - this finds methods already registered
        in the incant runtime
    *********************************************************/
    String actionName = "aCTion" + name;
    address = findMethodAddress(actionName);

    if !address
        address = findMethodAddress(name);

    return address;
}
A few things worth noting about this code:
The parseSignature method reuses the types registry from your generate file — that registry already has all the C++ type names you care about, so there's no duplication. The type codes it stores will feed directly into the JIT code generator when it needs to emit typed LLVM IR.
The lookupNativeAddress method deliberately piggybacks on the ruleMethod naming convention you already have. That means any method already accessible via ruleMethod is automatically accessible via nativeType too — no double registration needed.
