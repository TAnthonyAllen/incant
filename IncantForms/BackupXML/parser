define
    /*********************************************************
        inlineOps maps operator tags to their JIT inline
        strategy based on operand types. When both operands
        are known types at compile time, we emit a direct
        LLVM IR instruction instead of calling opPlus etc.
    *********************************************************/
    inlineOps registry;

    inlineOp
        leftType        // expected left operand type
        rightType       // expected right operand type
        llvmOp          // LLVM IR instruction to emit
        fallback;       // native method if types don't match

    /*********************************************************
        double + double -> fadd
        int + int       -> add
        string + string -> call opPlus (no inline for strings)
    *********************************************************/
    registerInlineOp name leftType rightType llvmOp fallback; {
        entry = new(inlineOp);
        entry.leftType  = leftType;
        entry.rightType = rightType;
        entry.llvmOp    = llvmOp;
        entry.fallback  = fallback;
        inlineOps += entry;
        setLabel(name);
    }
;

