/*******************************************************************************
    Fonts
    Mac fonts are stored in /Library/Fonts or /System/Library/Fonts
*******************************************************************************/
#registry fONTs base;
<courierFont font="Courier New" fontSize=24 bold/>
<titleFont font=Palatino fontSize=24 bold/>
<headerFont font=Palatino fontSize=14 bold/>
<normalFont font=Palatino fontSize=14/>
<copperFont font=Copperplate fontSize=12/>
<defaultFont normalFont/>
<EBgaramondFont font="EB Garamond" fontSize=18 bold/>
<libraryFonts directory="/Library/Fonts" mask=~'[.]tt[cf]' into=fONTs/>
<systemFonts directory="/System/Library/Fonts" mask=~'[.]tt[cf]' into=fONTs/>
#load libraryFonts;
#load systemFonts;
#;
