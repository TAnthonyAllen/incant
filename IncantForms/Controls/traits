<down/>
<dump/>
<fill/>
<italic=1/>
<label/>
<lineHeight/>
<mBottom/>
<mLeft/>
<mRight/>
<mTop/>
<minimumHeight="inherited attribute determines minumum height when height proportional or %"/>
<minimumWidth="inherited attribute determines minumum width when width proportional or %"/>
<pad/>
