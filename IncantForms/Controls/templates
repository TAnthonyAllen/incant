<head>
    <meta charset="UTF-8"></meta>
    <title>Drawing</title>
    <script type="text/javascript" buffer>
var canvas;
var ctx;
function rounded(x, y, width, height, radius, fillIt)
    {
    ctx.beginPath();
    ctx.moveTo(x, y + radius);
    ctx.lineTo(x, y + height - radius);
    ctx.arcTo(x, y + height, x + radius, y + height, radius);
    ctx.lineTo(x + width - radius, y + height);
    ctx.arcTo(x + width, y + height, x + width, y + height-radius, radius);
    ctx.lineTo(x + width, y + radius);
    ctx.arcTo(x + width, y, x + width - radius, y, radius);
    ctx.lineTo(x + radius, y);
    ctx.arcTo(x, y, x, y + radius, radius);
    if (fillIt) ctx.fill();
    ctx.stroke();
    ctx.closePath();
    }
function drawBox(x, y, width, height, radius, fillIt, filler, strokeIt, stroker)
    {
    var ofst = ctx.lineWidth;
    var lof = ofst * 2;
    ctx.save();
    if (filler)         ctx.fillStyle   = filler;
    if (stroker)        ctx.strokeStyle = stroker;
    if (radius)         rounded(x, y, width, height, radius, fillIt);
    else {
        if (fillIt)     ctx.fillRect(x+ofst,y+ofst,width-lof,height-lof);
        if (strokeIt)   ctx.strokeRect(x,y,width,height);
        }
    ctx.restore();
    }</head>
