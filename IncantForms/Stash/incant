/*******************************************************************************
	Return text containing funky characters wrapped in appropriate quotes.
    If text contains both " and ' you are screwed.
*******************************************************************************/
String wrap(String text)
{
String	at = text;
	if !isSET && mustQuoteSet.foundIn(text)
		{
		while *at && *at != '"' at++;
		if *at && at == '"' at = "'" text "'";
		else at = "\"" text "\"";
		}
	return at;
}

/*****************************************************************************
	If no item passed in, returns an empty string, otherwise it returns the
    item text, wrapping it in quotes if the text contains any character
    in the must quote set.
*****************************************************************************/
String wrapItem(PLGitem item)
{
String	at;
int		i;
    if !item return "";
    at = start;
    i = item.length;
	if mustQuoteSet.foundIn(item)
		{
		while i-- && *at != '"' at++;
		if *at && at == '"' at = "'" item "'";
		else at = "\"" item "\"";
		return at;
		}
	return item.toString();
}

/*******************************************************************************
	Return text appropriate value (handles regex)
*******************************************************************************/
String wrapValue()
{
String	at;
    if data
        if isMAP
            at = "isBitMAP";
        else
            {
            if isSET
                at = "[" characterSet.setBuffer.string() "]";
            or isREGEX && text
                at = "~'" text "'";
            or isGROUP
                {
                if group.isInitialized at = group.tag "=" group.wrapValue();
                else at = group.tag;
                }
            else    at = text;
            }
    return at;
}

/*****************************************************************************
	Writes the body into the buffer passed in.
*****************************************************************************/
void writeBody(Buffer buffet)
{
int			flag;
GroupItem	block;
String		junkText;
PLGitem		token;
    setMark();
	if isRigorous && data && !isGROUP
		{
		if isITEM
			for token = item
				{
				if token.noPrint continue;
				if !token.isEndTag
                    {
                    if tag          indent(buffet);
					print(buffet)   token;
                    }
				else print "</" wrap(token) ">";
				}
        else print text;
		junkText = buffet.getMarkedString();
		// At this point the buffer no longer contains text
		if isRigorous && cdataSet.contains(*junkText)
			{
			print "<![CDATA[";
			flag = true;
			}
		print junkText;
		if flag print "]]>";
		}
    if hasMembers
		{
		while block = nextMember(block)
            {
            if block.isTarget && ignoreNoRoom continue;
            debugIndent++;
            if !block.tag   print block;
			else print :block;
            debugIndent--;
            }
		}
}

/*******************************************************************************
	Writes out rule options
*******************************************************************************/
void writeOption(Buffer buffet)
{
    if isOption
        if plus          print "+";
        or star          print "*";
        or question      print "?";
    if banged            print "!";
    if noAdvance            print "<";
    if noSkip               print "&";
    if isAlternate          print "|";
    if noLabel              print "-";
    if unGuarded         print "_";
    print ,;
}

/*****************************************************************************
	Write tag to buffer
*****************************************************************************/
void writeTagXML(Buffer buffet)
{
GroupItem	group;
	//setMark();
    print "<";
    if !isRigorous
        {
        if isTarget print "@";
        if noAnchor print "%%";
        }
    print wrap(tag);
    if data && text
        if !isRigorous
            print "=" wrap(wrapValue());
        or isAttribute print "=\"" wrapValue() "\"";
    if isOption || noAdvance || noSkip writeOption(buffet);
    if hasAttributes
        {
        while group = nextAttribute(group)
            if !group.noPrint || ignoreNoPrint
                print group;
        if *(buffet.current - 1) == ' ' && buffet.current > buffet.start
            buffet.current--;
        }
    if isSingleton
        print "/>";
    else    print ">";
	//unMark();
}

/*******************************************************************************
	Generator method for the IF rule rule; invoked by aCTionIF when generating.
*******************************************************************************/
extern GroupItem genIF(GroupItem input)
{
GroupItem   expression  = input[1],
            statement   = input[2],
            Else        = input[3];
GroupRules  ruler;
    ruler   = groupRules;
use input
    clear();
    print(fieldBUFFER) "if (" expression.gText ") " statement.gText;
    if Else print Else;
    text = fieldBUFFER.toString();
    fieldBUFFER.reset();
    return input;
}
