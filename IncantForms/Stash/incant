*****************************************************************************/
void toFile(String filename)
{
    if isBUFFER
        {
        buffer.file = filename;
        buffer.flush();
        }
    else {
        Buffer  buff    = new;
        buff.file       = filename;
        debugIndent     = 0;
        toBuffer(buff);
        buff.flush();
        delete buff;
        }
}

