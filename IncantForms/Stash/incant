/***************************************************************************
        Returns a field whose tag is a qualified tag of the field passed in
***************************************************************************/
extern String getQualifiedTag(GroupItem input)
{
GroupRules  ruler = groupRules;
GroupItem   tagged = falseResult;
GroupItem   nextTag;
GroupItem   grup = input;
String      qualifiedTag;
use stringBUFFER
    reset();
    while grup {
        if isREGISTRY  break;
        nextTag = grup.parent;
        tagged  += grup;
        grup    = nextTag; }
    grup    = 0;
    while grup = tagged.prior(grup) {
        append(grup.tag);
        if grup.priorInParent   append('.'); }
    tagged.clear();
    qualifiedTag = toString();
    return qualifiedTag;
}

/***************************************************************************
	Sets toggle fields in GroupFields registry
***************************************************************************/
extern GroupItem toggle(GroupItem toggleItem)
{
GroupRules  ruler   = groupRules;
GroupItem   grup    = toggleItem.parent;
GroupItem   entry;
int         i;
    while entry = grup.next(entry) {
        entry.count     = ++i;
        entry.isToggle  = true;
        entry.registry  = grup;
        groupFields     += entry; }
    return grup;
}

/*****************************************************************************
	returns a copy of this group filtering out unwanted attributes.
    Only the attributes matching the attributes of the item passed are
    copied. All members are retained.
*****************************************************************************/
GroupItem filter(GroupItem item)
{
GroupItem	keep,
            group = new(tag);
    if hasAttributes
        {
        while keep = next(keep)
            if keep.isAttribute
                {
                if !item.getAttribute(keep.tag) continue;
                group += keep;
                }
            else group += keep;
        }
    return group;
}

/*****************************************************************************
	Print out group as an xml block to the buffer passed in.
*****************************************************************************/
void toBuffer(Buffer buffet)
{
String		junkText;
    if noPrint && ignoreNoPrint return;
    if isTarget && ignoreNoRoom return;
    if isAttribute && parent
        {
        if data junkText = wrapValue();
        if isRigorous && junkText print tag  "=\"" junkText "\"";
        print(buffet) " ";
        if isTarget print "@";
        if !isRigorous
            {
            print wrap(tag);
            if junkText print "=" wrap(junkText);
            }
        if isOption || noAdvance || noSkip writeOption(buffet);
        return;
        }
    if tag  writeTagXML(buffet);
    or isSingleton
        print "</" tag ">";         // Not an end tag just looks like one
    if !isSingleton
		{
        if hasMembers || (data && !isAttribute)
            writeBody(buffet);
		if tag
			{
			print "</";
			buffet += wrap(tag);
			print ">";
            //if !parent print :;
			}
		}
finish:
	return;
}

/*****************************************************************************
